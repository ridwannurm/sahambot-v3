# ─────────────────────────────────────────────────
#  SahamBot v2 — Konfigurasi API Keys
#  Salin file ini menjadi .env lalu isi nilainya
# ─────────────────────────────────────────────────

# ── AI Providers (isi minimal SATU) ──────────────

# Claude / Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI / ChatGPT — https://platform.openai.com
OPENAI_API_KEY=sk-xxxxx

# Groq (GRATIS & CEPAT) — https://console.groq.com
GROQ_API_KEY=gsk_xxxxx

# Google Gemini — https://aistudio.google.com
GEMINI_API_KEY=AIzaSyxxxxx

# Ollama (lokal, tidak perlu key) — http://localhost:11434
# OLLAMA_URL=http://localhost:11434

# ── Telegram Bot ─────────────────────────────────

# Buat bot baru via @BotFather di Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCxxxxx

# Chat ID untuk auto scan (cek via @userinfobot di Telegram)
TELEGRAM_CHAT_ID=123456789
